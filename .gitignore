# ================================
# 🔐 ENV & SECRETS (CRITICAL)
# ================================
.env
.env.*
*.env

# ================================
# 🧠 DATA (DO NOT PUSH)
# ================================
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ================================
# 🧾 LOGS
# ================================
*.log

# ================================
# 🐍 PYTHON CACHE
# ================================
__pycache__/
*.py[codz]
*$py.class

# ================================
# 📦 BUILD / DIST
# ================================
build/
dist/
*.egg-info/
.eggs/

# ================================
# 🧪 TEST / COVERAGE
# ================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ================================
# 📓 JUPYTER
# ================================
.ipynb_checkpoints/

# ================================
# 🧠 ML / EXPERIMENT TRACKING
# ================================
mlruns/
wandb/

# ================================
# ⚙️ VIRTUAL ENVIRONMENTS
# ================================
.venv/
venv/
env/

# ================================
# 💻 IDE / EDITOR
# ================================
.vscode/
.idea/

# ================================
# 🖥️ OS FILES
# ================================
.DS_Store
Thumbs.db

# ================================
# ⚡ OPTIONAL (if using)
# ================================
*.sqlite3
*.db
*.pkl
api.log
echo README_OLD.md >> .gitignore